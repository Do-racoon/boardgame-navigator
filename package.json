{
  "name": "boardgame-navigator",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "pnpm --filter @boardgame/database db:push",
    "db:studio": "pnpm --filter @boardgame/database db:studio",
    "db:seed": "pnpm --filter @boardgame/database db:seed",
    "ingest": "pnpm --filter @boardgame/ingest ingest"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "pg": "^8.22.0"
  }
}
