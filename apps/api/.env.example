DATABASE_URL=postgresql://user:password@localhost:5432/boardgame

# OpenAI - 임베딩 전용 (text-embedding-3-large)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic Claude - 답변 생성 전용
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# Azure Blob Storage - PDF 파일 저장 (선택, MVP에서는 로컬 경로 사용 가능)
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=rulebooks

FRONTEND_URL=http://localhost:3000
PORT=4000
